{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Task 003 dependency license offline manifest",
  "type": "object",
  "required": ["document_type", "task_id", "candidate_id", "version", "artifact_inventory", "legal_files", "offline_install"],
  "properties": {
    "document_type": {"const": "dependency_license_offline_manifest"},
    "task_id": {"const": "hwpx-core-benchmark-003-evidence-integrity"},
    "candidate_id": {"type": "string", "minLength": 1},
    "version": {"type": "string", "minLength": 1},
    "artifact_inventory": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/artifact"}},
    "legal_files": {"type": "array", "minItems": 3, "items": {"$ref": "#/$defs/legal"}},
    "spdx_expression": {"type": ["string", "null"]},
    "redistribution": {"type": "object", "required": ["source_impact", "binary_impact", "obligations"], "properties": {"source_impact": {"type": "string", "not": {"const": "unknown"}}, "binary_impact": {"type": "string", "not": {"const": "unknown"}}, "obligations": {"type": "array", "minItems": 1, "items": {"type": "string"}}}, "additionalProperties": false},
    "offline_install": {"type": "object", "required": ["clean_environment", "install_attempt", "runtime_invocation", "network_test", "cleanup"], "properties": {"clean_environment": {"type": "object"}, "install_attempt": {"type": "object"}, "runtime_invocation": {"type": "object"}, "network_test": {"type": "object"}, "cleanup": {"type": "object"}}, "additionalProperties": false}
  },
  "$defs": {
    "artifact": {"type": "object", "required": ["path", "size", "sha256"], "properties": {"path": {"type": "string", "minLength": 1}, "size": {"type": "integer", "minimum": 0}, "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}}, "additionalProperties": false},
    "legal": {"type": "object", "required": ["kind", "status"], "properties": {"kind": {"enum": ["LICENSE", "COPYING", "NOTICE"]}, "status": {"enum": ["present", "absent"]}, "path": {"type": "string"}, "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}, "rationale": {"type": "string"}}, "allOf": [{"if": {"properties": {"status": {"const": "present"}}}, "then": {"required": ["path", "sha256"]}}, {"if": {"properties": {"status": {"const": "absent"}}}, "then": {"required": ["rationale"]}}], "additionalProperties": false}
  },
  "additionalProperties": false
}
