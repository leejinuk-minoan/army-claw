{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Task 003 test summary",
  "type": "object",
  "required": [
    "task_id",
    "independent_ci_verification",
    "runs"
  ],
  "properties": {
    "task_id": {
      "const": "hwpx-core-benchmark-003-evidence-integrity"
    },
    "independent_ci_verification": {
      "type": "string"
    },
    "runs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "command",
          "exit_code",
          "passed",
          "failed",
          "skipped"
        ],
        "properties": {
          "command": {
            "type": "string"
          },
          "exit_code": {
            "type": "number"
          },
          "passed": {
            "type": "number",
            "minimum": 0
          },
          "failed": {
            "type": "number",
            "minimum": 0
          },
          "skipped": {
            "type": "number",
            "minimum": 0
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
