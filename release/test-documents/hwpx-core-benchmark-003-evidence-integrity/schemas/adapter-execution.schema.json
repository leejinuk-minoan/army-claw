{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Task 003 adapter execution",
  "type": "object",
  "required": ["task_id", "candidate_id", "scenario_id", "method", "status", "planned_commands", "attempted_commands", "checked_paths"],
  "properties": {
    "task_id": {"const": "hwpx-core-benchmark-003-evidence-integrity"},
    "candidate_id": {"type": "string", "minLength": 1},
    "scenario_id": {"type": "string", "pattern": "^S(0[1-9]|1[0-4])$"},
    "method": {"type": "string", "minLength": 1},
    "status": {"enum": ["passed", "failed", "unsupported", "blocked", "not_applicable"]},
    "planned_commands": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "attempted_commands": {"type": "array", "items": {"$ref": "#/$defs/command"}},
    "checked_paths": {"type": "array", "items": {"$ref": "#/$defs/pathProbe"}}
  },
  "allOf": [
    {"if": {"properties": {"status": {"const": "passed"}}}, "then": {"properties": {"attempted_commands": {"minItems": 1}}}},
    {"if": {"properties": {"status": {"const": "not_applicable"}}}, "then": {"properties": {"attempted_commands": {"maxItems": 0}}}}
  ],
  "$defs": {
    "command": {"type": "object", "required": ["command", "executed", "started_at", "ended_at", "exit_code", "stdout_path", "stderr_path"], "properties": {"command": {"type": "string", "minLength": 1}, "executed": {"const": true}, "started_at": {"type": "string", "format": "date-time"}, "ended_at": {"type": "string", "format": "date-time"}, "exit_code": {"type": "integer"}, "stdout_path": {"type": "string", "minLength": 1}, "stderr_path": {"type": "string", "minLength": 1}}, "additionalProperties": false},
    "pathProbe": {"type": "object", "required": ["path", "exists"], "properties": {"path": {"type": "string", "minLength": 1}, "exists": {"type": "boolean"}, "sha256": {"type": ["string", "null"], "pattern": "^[a-f0-9]{64}$"}, "size": {"type": ["integer", "null"], "minimum": 0}}, "additionalProperties": false}
  },
  "additionalProperties": false
}
