{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Task 003 canonical dependency and legal evidence manifest",
  "type": "object",
  "required": ["schema_version", "document_type", "task_id", "candidate_id", "version", "upstream_artifact", "artifact_inventory", "runtime_dependency_inventory", "offline_install", "legal_files", "redistribution", "reviewer", "reviewed_at"],
  "properties": {
    "schema_version": {"const": "2.1.0"},
    "document_type": {"const": "dependency_license_offline_manifest"},
    "task_id": {"const": "hwpx-core-benchmark-003-evidence-integrity"},
    "candidate_id": {"type": "string", "minLength": 1},
    "version": {"type": "string", "minLength": 1},
    "upstream_artifact": {"$ref": "#/$defs/fileReference"},
    "artifact_inventory": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/fileReference"}},
    "runtime_dependency_inventory": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/fileReference"}},
    "offline_install": {"$ref": "#/$defs/offlineInstall"},
    "legal_files": {
      "type": "array",
      "minItems": 3,
      "items": {"$ref": "#/$defs/legalFile"},
      "allOf": [
        {"contains": {"type": "object", "properties": {"kind": {"const": "LICENSE"}}, "required": ["kind"]}, "minContains": 1, "maxContains": 1},
        {"contains": {"type": "object", "properties": {"kind": {"const": "COPYING"}}, "required": ["kind"]}, "minContains": 1, "maxContains": 1},
        {"contains": {"type": "object", "properties": {"kind": {"const": "NOTICE"}}, "required": ["kind"]}, "minContains": 1, "maxContains": 1}
      ]
    },
    "spdx_expression": {"type": ["string", "null"]},
    "manual_assessment": {"type": ["object", "null"], "properties": {"text": {"type": "string", "minLength": 1}, "evidence_path": {"type": "string", "minLength": 1}}, "required": ["text", "evidence_path"], "additionalProperties": false},
    "redistribution": {"type": "object", "required": ["source_impact", "binary_impact", "obligations"], "properties": {"source_impact": {"type": "string", "minLength": 1, "not": {"const": "unknown"}}, "binary_impact": {"type": "string", "minLength": 1, "not": {"const": "unknown"}}, "obligations": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}}, "additionalProperties": false},
    "reviewer": {"type": "string", "minLength": 1},
    "reviewed_at": {"type": "string", "format": "date-time"}
  },
  "anyOf": [
    {"required": ["spdx_expression"], "properties": {"spdx_expression": {"type": "string", "minLength": 1}}},
    {"required": ["manual_assessment"], "properties": {"manual_assessment": {"type": "object"}}}
  ],
  "$defs": {
    "fileProbe": {"type": "object", "required": ["path", "exists", "size", "sha256", "hash_algorithm", "source"], "properties": {"path": {"type": "string", "minLength": 1}, "exists": {"const": true}, "size": {"type": "integer", "minimum": 0}, "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}, "hash_algorithm": {"const": "sha256"}, "source": {"const": "filesystem"}}, "additionalProperties": false},
    "fileReference": {"type": "object", "required": ["path", "size", "sha256", "probe"], "properties": {"path": {"type": "string", "minLength": 1}, "size": {"type": "integer", "minimum": 0}, "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}, "probe": {"$ref": "#/$defs/fileProbe"}}, "additionalProperties": false},
    "command": {"type": "object", "required": ["command", "executed", "method", "started_at", "ended_at", "exit_code", "stdout_path", "stderr_path", "stdout_probe", "stderr_probe"], "properties": {"command": {"type": "string", "minLength": 1}, "executed": {"const": true}, "method": {"type": "string", "minLength": 1}, "started_at": {"type": "string", "format": "date-time"}, "ended_at": {"type": "string", "format": "date-time"}, "exit_code": {"type": "integer"}, "stdout_path": {"type": "string", "minLength": 1}, "stderr_path": {"type": "string", "minLength": 1}, "stdout_probe": {"$ref": "#/$defs/fileProbe"}, "stderr_probe": {"$ref": "#/$defs/fileProbe"}}, "additionalProperties": false},
    "offlineInstall": {"type": "object", "required": ["clean_environment", "offline_artifacts", "install_attempt", "installed_inventory", "runtime_invocation", "network_test_evidence", "cleanup_evidence"], "properties": {"clean_environment": {"type": "object", "required": ["type", "path_or_id", "isolated"], "properties": {"type": {"type": "string", "minLength": 1}, "path_or_id": {"type": "string", "minLength": 1}, "isolated": {"const": true}}, "additionalProperties": false}, "offline_artifacts": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/fileReference"}}, "install_attempt": {"$ref": "#/$defs/command"}, "installed_inventory": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/fileReference"}}, "runtime_invocation": {"$ref": "#/$defs/command"}, "network_test_evidence": {"$ref": "#/$defs/fileReference"}, "cleanup_evidence": {"$ref": "#/$defs/fileReference"}}, "additionalProperties": false},
    "legalFile": {"type": "object", "required": ["kind", "path", "size", "sha256", "probe", "upstream_artifact_path", "upstream_artifact_sha256"], "properties": {"kind": {"enum": ["LICENSE", "COPYING", "NOTICE"]}, "path": {"type": "string", "minLength": 1}, "size": {"type": "integer", "minimum": 0}, "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}, "probe": {"$ref": "#/$defs/fileProbe"}, "upstream_artifact_path": {"type": "string", "minLength": 1}, "upstream_artifact_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}}, "additionalProperties": false}
  },
  "additionalProperties": false
}
