{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Task 003 canonical benchmark result",
  "type": "object",
  "required": ["task_id", "candidate_id", "candidate_role", "scenario_id", "status", "status_reason", "evidence_completeness", "missing_evidence", "planned_commands", "attempted_commands", "validator_results"],
  "properties": {
    "task_id": {"const": "hwpx-core-benchmark-003-evidence-integrity"},
    "candidate_id": {"type": "string", "minLength": 1},
    "candidate_role": {"enum": ["editor", "validator", "layout_authority"]},
    "scenario_id": {"type": "string", "pattern": "^S(0[1-9]|1[0-4])$"},
    "status": {"enum": ["passed", "failed", "unsupported", "blocked", "not_applicable"]},
    "status_reason": {"type": "string", "minLength": 1},
    "evidence_completeness": {"enum": ["complete", "partial", "missing", "not_applicable"]},
    "missing_evidence": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "planned_commands": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "attempted_commands": {"type": "array", "items": {"$ref": "#/$defs/command"}},
    "validator_results": {"type": "array", "items": {"$ref": "#/$defs/validator"}},
    "imported_evidence": {"type": ["object", "null"]},
    "prerequisite_probe": {"type": ["object", "null"]},
    "source_api_inspection": {"type": ["object", "null"]},
    "blocked_reason_code": {"type": "string", "minLength": 1},
    "missing_prerequisites": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "rationale": {"type": "string", "minLength": 1},
    "governing_role_matrix_reference": {"type": "string", "minLength": 1}
  },
  "allOf": [
    {"if": {"properties": {"status": {"const": "passed"}}, "required": ["status"]}, "then": {"required": ["imported_evidence"], "properties": {"evidence_completeness": {"const": "complete"}, "missing_evidence": {"maxItems": 0}, "attempted_commands": {"minItems": 1, "items": {"$ref": "#/$defs/successfulCommand"}}, "validator_results": {"minItems": 1, "items": {"$ref": "#/$defs/passedValidator"}}, "imported_evidence": {"$ref": "#/$defs/importedEvidence"}}}},
    {"if": {"properties": {"status": {"const": "blocked"}}, "required": ["status"]}, "then": {"required": ["prerequisite_probe", "blocked_reason_code", "missing_prerequisites"], "properties": {"prerequisite_probe": {"$ref": "#/$defs/blockingProbe"}}}},
    {"if": {"properties": {"status": {"const": "unsupported"}}, "required": ["status"]}, "then": {"required": ["source_api_inspection"], "properties": {"source_api_inspection": {"$ref": "#/$defs/unsupportedInspection"}}}},
    {"if": {"properties": {"status": {"const": "not_applicable"}}, "required": ["status"]}, "then": {"required": ["candidate_role", "rationale", "governing_role_matrix_reference"], "properties": {"evidence_completeness": {"const": "not_applicable"}, "missing_evidence": {"maxItems": 0}, "attempted_commands": {"maxItems": 0}}}}
  ],
  "$defs": {
    "fileProbe": {"type": "object", "required": ["path", "exists", "size", "sha256", "hash_algorithm", "source"], "properties": {"path": {"type": "string", "minLength": 1}, "exists": {"const": true}, "size": {"type": "integer", "minimum": 0}, "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}, "hash_algorithm": {"const": "sha256"}, "source": {"const": "filesystem"}}, "additionalProperties": false},
    "command": {"type": "object", "required": ["command", "executed", "method", "started_at", "ended_at", "exit_code", "stdout_path", "stderr_path", "stdout_probe", "stderr_probe"], "properties": {"command": {"type": "string", "minLength": 1}, "executed": {"const": true}, "method": {"type": "string", "minLength": 1}, "started_at": {"type": "string", "format": "date-time"}, "ended_at": {"type": "string", "format": "date-time"}, "exit_code": {"type": "integer"}, "stdout_path": {"type": "string", "minLength": 1}, "stderr_path": {"type": "string", "minLength": 1}, "stdout_probe": {"$ref": "#/$defs/fileProbe"}, "stderr_probe": {"$ref": "#/$defs/fileProbe"}}, "additionalProperties": false},
    "successfulCommand": {"allOf": [{"$ref": "#/$defs/command"}, {"properties": {"exit_code": {"const": 0}}}]},
    "validator": {"type": "object", "required": ["validator_id", "valid", "missing_evidence", "assertions"], "properties": {"validator_id": {"type": "string"}, "valid": {"type": "boolean"}, "missing_evidence": {"type": "array", "items": {"type": "string"}}, "assertions": {"type": "array", "items": {"type": "object", "required": ["assertion_id", "expected", "actual", "passed"}, "properties": {"assertion_id": {"type": "string"}, "expected": {}, "actual": {}, "passed": {"type": "boolean"}, "evidence_path": {"type": "string"}}, "additionalProperties": false}}, "additionalProperties": false},
    "passedValidator": {"allOf": [{"$ref": "#/$defs/validator"}, {"properties": {"valid": {"const": true}, "missing_evidence": {"maxItems": 0}}}]},
    "importedEvidence": {"type": "object", "required": ["source_path", "source_sha256", "hash_verified", "source_probe"], "properties": {"source_path": {"type": "string"}, "source_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}, "hash_verified": {"const": true}, "source_probe": {"$ref": "#/$defs/fileProbe"}}, "additionalProperties": false},
    "blockingProbe": {"type": "object", "required": ["performed", "available", "method", "probe_evidence_path", "probe_evidence_sha256", "checked_path_results", "blocked_reason_code", "missing_prerequisites"], "properties": {"performed": {"const": true}, "available": {"const": false}, "method": {"type": "string"}, "probe_evidence_path": {"type": "string"}, "probe_evidence_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}, "checked_path_results": {"type": "array", "minItems": 1, "items": {"type": "object"}}, "blocked_reason_code": {"type": "string", "minLength": 1}, "missing_prerequisites": {"type": "array", "minItems": 1, "items": {"type": "string"}}}, "additionalProperties": false},
    "unsupportedInspection": {"type": "object", "required": ["performed", "supported", "method", "evidence_path", "evidence_sha256"], "properties": {"performed": {"const": true}, "supported": {"const": false}, "method": {"type": "string"}, "evidence_path": {"type": "string"}, "evidence_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}, "rationale": {"type": "string"}}, "additionalProperties": false}
  },
  "additionalProperties": false
}
