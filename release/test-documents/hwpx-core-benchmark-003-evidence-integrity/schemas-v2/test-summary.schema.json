{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Task 003 canonical test summary",
  "type": "object",
  "required": ["schema_version", "document_type", "task_id", "tested_implementation_commit_sha", "independent_ci_verification", "totals", "required_runs", "optional_runs", "invalid_pass_count", "schema_validation_failures", "completion_gate_passed"],
  "properties": {
    "schema_version": {"const": "2.1.0"},
    "document_type": {"const": "test_summary"},
    "task_id": {"const": "hwpx-core-benchmark-003-evidence-integrity"},
    "tested_implementation_commit_sha": {"type": "string", "pattern": "^[a-f0-9]{40}$"},
    "independent_ci_verification": {"$ref": "#/$defs/independentCi"},
    "totals": {"type": "object", "required": ["passed", "failed", "skipped"], "properties": {"passed": {"type": "integer", "minimum": 0}, "failed": {"type": "integer", "minimum": 0}, "skipped": {"type": "integer", "minimum": 0}}, "additionalProperties": false},
    "required_runs": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/run"}},
    "optional_runs": {"type": "array", "items": {"$ref": "#/$defs/run"}},
    "invalid_pass_count": {"type": "integer", "minimum": 0},
    "schema_validation_failures": {"type": "integer", "minimum": 0},
    "completion_gate_passed": {"type": "boolean"},
    "limitations": {"type": "array", "items": {"type": "string", "minLength": 1}}
  },
  "allOf": [
    {
      "if": {"properties": {"completion_gate_passed": {"const": true}}, "required": ["completion_gate_passed"]},
      "then": {
        "properties": {
          "totals": {"properties": {"failed": {"const": 0}}},
          "required_runs": {"items": {"$ref": "#/$defs/successfulRun"}},
          "invalid_pass_count": {"const": 0},
          "schema_validation_failures": {"const": 0}
        }
      }
    },
    {
      "if": {"properties": {"completion_gate_passed": {"const": true}, "independent_ci_verification": {"properties": {"required_for_completion": {"const": true}}}}, "required": ["completion_gate_passed", "independent_ci_verification"]},
      "then": {"properties": {"independent_ci_verification": {"properties": {"status": {"const": "executed"}}}}}
    }
  ],
  "$defs": {
    "independentCi": {
      "type": "object",
      "required": ["required_for_completion", "status", "limitation"],
      "properties": {
        "required_for_completion": {"type": "boolean"},
        "status": {"enum": ["executed", "not_performed", "not_required"]},
        "limitation": {"type": "string"},
        "evidence_path": {"type": ["string", "null"]},
        "evidence_sha256": {"type": ["string", "null"], "pattern": "^[a-f0-9]{64}$"}
      },
      "additionalProperties": false
    },
    "run": {
      "type": "object",
      "required": ["run_id", "required_for_completion", "executed", "exit_code", "passed", "failed", "stdout_path", "stderr_path"],
      "properties": {
        "run_id": {"type": "string", "minLength": 1},
        "required_for_completion": {"type": "boolean"},
        "executed": {"type": "boolean"},
        "exit_code": {"type": ["integer", "null"]},
        "passed": {"type": "boolean"},
        "failed": {"type": "integer", "minimum": 0},
        "stdout_path": {"type": ["string", "null"]},
        "stderr_path": {"type": ["string", "null"]},
        "limitation": {"type": "string"}
      },
      "additionalProperties": false
    },
    "successfulRun": {
      "allOf": [
        {"$ref": "#/$defs/run"},
        {"properties": {"required_for_completion": {"const": true}, "executed": {"const": true}, "exit_code": {"const": 0}, "passed": {"const": true}, "failed": {"const": 0}, "stdout_path": {"type": "string", "minLength": 1}, "stderr_path": {"type": "string", "minLength": 1}}}
      ]
    }
  },
  "additionalProperties": false
}
