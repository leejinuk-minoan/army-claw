{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Task 003 canonical adapter execution",
  "type": "object",
  "required": ["task_id", "candidate_id", "candidate_role", "scenario_id", "status", "planned_commands", "attempted_commands", "validator_results", "missing_evidence", "evidence_completeness"],
  "properties": {
    "task_id": { "const": "hwpx-core-benchmark-003-evidence-integrity" },
    "candidate_id": { "type": "string", "minLength": 1 },
    "candidate_role": { "enum": ["editor", "validator", "layout_authority"] },
    "scenario_id": { "type": "string", "pattern": "^S(0[1-9]|1[0-4])$" },
    "status": { "enum": ["passed", "failed", "unsupported", "blocked", "not_applicable"] },
    "planned_commands": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
    "attempted_commands": { "type": "array", "items": { "$ref": "#/$defs/command" } },
    "execution_outcome": { "enum": ["success", "failure", "not_executed"] },
    "status_reason": { "type": "string", "minLength": 1 },
    "source_api_inspection": { "oneOf": [{ "$ref": "#/$defs/sourceApiInspection" }, { "type": "null" }] },
    "prerequisite_probe": { "oneOf": [{ "$ref": "#/$defs/prerequisiteProbe" }, { "type": "null" }] },
    "blocked_reason_code": { "type": "string", "minLength": 1 },
    "missing_prerequisites": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
    "not_applicable_rationale": { "type": "string", "minLength": 1 },
    "role_matrix_reference": { "type": "string", "minLength": 1 },
    "validator_results": { "type": "array", "items": { "$ref": "#/$defs/validatorResult" } },
    "missing_evidence": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
    "evidence_completeness": { "enum": ["complete", "partial", "missing", "not_applicable"] }
  },
  "allOf": [
    {
      "if": { "properties": { "status": { "const": "passed" } }, "required": ["status"] },
      "then": {
        "required": ["execution_outcome"],
        "properties": {
          "execution_outcome": { "const": "success" },
          "attempted_commands": { "minItems": 1, "items": { "$ref": "#/$defs/successfulCommand" } },
          "validator_results": { "minItems": 1, "items": { "$ref": "#/$defs/passedValidator" } },
          "missing_evidence": { "maxItems": 0 },
          "evidence_completeness": { "const": "complete" }
        }
      }
    },
    {
      "if": { "properties": { "status": { "const": "failed" } }, "required": ["status"] },
      "then": {
        "properties": { "attempted_commands": { "minItems": 1 } },
        "allOf": [
          { "anyOf": [{ "required": ["execution_outcome"] }, { "required": ["status_reason"] }] },
          {
            "anyOf": [
              { "properties": { "attempted_commands": { "contains": { "$ref": "#/$defs/failedCommand" }, "minContains": 1 } } },
              { "properties": { "validator_results": { "contains": { "$ref": "#/$defs/failedValidator" }, "minContains": 1 } } }
            ]
          }
        ]
      }
    },
    {
      "if": { "properties": { "status": { "const": "blocked" } }, "required": ["status"] },
      "then": {
        "required": ["prerequisite_probe", "blocked_reason_code", "missing_prerequisites"],
        "properties": {
          "prerequisite_probe": { "$ref": "#/$defs/blockingPrerequisiteProbe" },
          "missing_prerequisites": { "minItems": 1 }
        }
      }
    },
    {
      "if": { "properties": { "status": { "const": "unsupported" } }, "required": ["status"] },
      "then": {
        "required": ["source_api_inspection"],
        "properties": { "source_api_inspection": { "$ref": "#/$defs/unsupportedSourceApiInspection" } }
      }
    },
    {
      "if": { "properties": { "status": { "const": "not_applicable" } }, "required": ["status"] },
      "then": {
        "required": ["not_applicable_rationale", "candidate_role", "role_matrix_reference"],
        "properties": {
          "attempted_commands": { "maxItems": 0 },
          "missing_evidence": { "maxItems": 0 },
          "evidence_completeness": { "const": "not_applicable" }
        }
      }
    }
  ],
  "$defs": {
    "fileProbe": {
      "type": "object",
      "required": ["path", "exists", "size", "sha256", "hash_algorithm", "source"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "exists": { "const": true },
        "size": { "type": "integer", "minimum": 0 },
        "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "hash_algorithm": { "const": "sha256" },
        "source": { "const": "filesystem" }
      },
      "additionalProperties": false
    },
    "pathProbe": {
      "type": "object",
      "required": ["path", "exists", "size", "sha256", "hash_algorithm", "source"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "exists": { "type": "boolean" },
        "size": { "type": ["integer", "null"], "minimum": 0 },
        "sha256": { "type": ["string", "null"], "pattern": "^[a-f0-9]{64}$" },
        "hash_algorithm": { "type": ["string", "null"] },
        "source": { "type": ["string", "null"] }
      },
      "allOf": [
        { "if": { "properties": { "exists": { "const": true } }, "required": ["exists"] }, "then": { "properties": { "size": { "type": "integer", "minimum": 0 }, "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }, "hash_algorithm": { "const": "sha256" }, "source": { "const": "filesystem" } } } },
        { "if": { "properties": { "exists": { "const": false } }, "required": ["exists"] }, "then": { "properties": { "size": { "const": null }, "sha256": { "const": null }, "hash_algorithm": { "const": null }, "source": { "const": null } } } }
      ],
      "additionalProperties": false
    },
    "command": {
      "type": "object",
      "required": ["command", "executed", "method", "started_at", "ended_at", "exit_code", "stdout_path", "stderr_path", "stdout_probe", "stderr_probe"],
      "properties": {
        "command": { "type": "string", "minLength": 1 },
        "executed": { "const": true },
        "method": { "type": "string", "minLength": 1 },
        "started_at": { "type": "string", "format": "date-time" },
        "ended_at": { "type": "string", "format": "date-time" },
        "exit_code": { "type": "integer" },
        "stdout_path": { "type": "string", "minLength": 1 },
        "stderr_path": { "type": "string", "minLength": 1 },
        "stdout_probe": { "$ref": "#/$defs/fileProbe" },
        "stderr_probe": { "$ref": "#/$defs/fileProbe" }
      },
      "additionalProperties": false
    },
    "successfulCommand": { "allOf": [{ "$ref": "#/$defs/command" }, { "properties": { "exit_code": { "const": 0 } } }] },
    "failedCommand": { "allOf": [{ "$ref": "#/$defs/command" }, { "properties": { "exit_code": { "not": { "const": 0 } } } }] },
    "validatorResult": {
      "type": "object",
      "required": ["validator_id", "valid", "missing_evidence", "assertions"],
      "properties": {
        "validator_id": { "type": "string", "minLength": 1 },
        "valid": { "type": "boolean" },
        "missing_evidence": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "assertions": { "type": "array", "items": { "$ref": "#/$defs/assertion" } }
      },
      "additionalProperties": false
    },
    "passedValidator": { "allOf": [{ "$ref": "#/$defs/validatorResult" }, { "properties": { "valid": { "const": true }, "missing_evidence": { "maxItems": 0 } } }] },
    "failedValidator": { "allOf": [{ "$ref": "#/$defs/validatorResult" }, { "properties": { "valid": { "const": false } } }] },
    "assertion": {
      "type": "object",
      "required": ["assertion_id", "expected", "actual", "passed"],
      "properties": {
        "assertion_id": { "type": "string", "minLength": 1 },
        "expected": {},
        "actual": {},
        "passed": { "type": "boolean" },
        "evidence_path": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "sourceApiInspection": {
      "type": "object",
      "required": ["inspection_target", "method", "result", "evidence_path", "evidence_sha256"],
      "properties": {
        "inspection_target": { "type": "string", "minLength": 1 },
        "method": { "type": "string", "minLength": 1 },
        "result": { "enum": ["supported", "unsupported"] },
        "evidence_path": { "type": "string", "minLength": 1 },
        "evidence_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "rationale": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "unsupportedSourceApiInspection": { "allOf": [{ "$ref": "#/$defs/sourceApiInspection" }, { "properties": { "result": { "const": "unsupported" } } }] },
    "prerequisiteProbe": {
      "type": "object",
      "required": ["performed", "available", "method", "probe_evidence_path", "probe_evidence_sha256", "checked_path_results"],
      "properties": {
        "performed": { "const": true },
        "available": { "type": "boolean" },
        "method": { "type": "string", "minLength": 1 },
        "probe_evidence_path": { "type": "string", "minLength": 1 },
        "probe_evidence_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "checked_path_results": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/pathProbe" } },
        "blocked_reason_code": { "type": "string", "minLength": 1 },
        "missing_prerequisites": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true }
      },
      "additionalProperties": false
    },
    "blockingPrerequisiteProbe": {
      "allOf": [
        { "$ref": "#/$defs/prerequisiteProbe" },
        {
          "required": ["blocked_reason_code", "missing_prerequisites"],
          "properties": {
            "available": { "const": false },
            "missing_prerequisites": { "minItems": 1 }
          }
        }
      ]
    }
  },
  "additionalProperties": false
}
