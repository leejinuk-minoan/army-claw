    "local_execution_base_sha": "string | null",
    "validator_cli": {
      "executed": "boolean",
      "command": "string",
      "exit_code": "integer | null",
      "stdout_path": "string | null",
      "stderr_path": "string | null",
      "result_status": "valid | invalid | blocked | not_evaluated | not_applicable | null",
      "total_checks": "integer | null",
