    "adapter_validator_gate_status",
    "adapter_validator_evidence_path",
    "validator_cli_exit_code",
    "unittest_exit_code",
    "gate_blocked_reason"
  ],
  "completion_gate_rules": [
    "if_adapter_validator_gate_required_true_evidence_must_exist",
    "if_adapter_validator_gate_required_true_validator_cli_exit_code_must_be_zero",
    "if_adapter_validator_gate_required_true_unittest_exit_code_must_be_zero",
    "if_evidence_missing_completion_gate_passed_must_be_false",
    "if_gate_failed_or_blocked_completion_gate_passed_must_be_false",
    "report_must_distinguish_not_required_from_required_not_run"
  ],
  "blocked_conditions": [
    "gate_status_missing_when_required",
    "required_not_run_at_completion",
    "validator_cli_exit_code_nonzero",
    "unittest_exit_code_nonzero",
    "execution_evidence_missing",
    "claiming_passed_without_execution_evidence",
    "actual_adapter_invocation_unapproved",
    "local_hancom_com_execution_unapproved"
  ],
  "forbidden_completion_claims": [
    "completion_gate_passed_true_with_required_not_run",
    "completion_gate_passed_true_with_failed_gate",
    "completion_gate_passed_true_with_blocked_gate",
    "validator_passed_claim_without_stdout_stderr_exit_code",
    "adapter_execution_claim_without_adapter_task_authorization"
  ],
